# Echo configuration — copy to .env and edit.
# Every value has a sensible default; you only need to set what you want to override.

# ─── Core ────────────────────────────────────
# ECHO_HOST=0.0.0.0
# ECHO_PORT=8420
# ECHO_DATA_DIR=./data

# ─── SSL (auto-generated on first boot if missing) ───
# Browser mic capture needs HTTPS (or http://localhost). Echo self-signs a cert.
# SSL_CERT_FILE=./certs/cert.pem
# SSL_KEY_FILE=./certs/key.pem
# SSL_AUTO_GENERATE=true

# ─── Whisper ─────────────────────────────────
# WHISPER_BACKEND=auto                          # auto | cuda | metal | cpu (build-time hint for install_whisper)
# WHISPER_MODEL=ggml-large-v3-turbo-q5_0.bin    # initial model; switch any time from the in-app model manager
# WHISPER_THREADS=4
# WHISPER_TTL_SECONDS=300                        # stop idle whisper-server after this many seconds
